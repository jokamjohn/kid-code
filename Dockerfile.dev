FROM node:22-alpine
RUN corepack enable

WORKDIR /app

# Workspace manifests — copy all before installing (cache layer)
COPY package.json pnpm-workspace.yaml pnpm-lock.yaml .npmrc ./
COPY api/package.json ./api/

# Install only frontend deps
RUN pnpm install --frozen-lockfile --filter kid-code

# Source is mounted as a volume at runtime — no COPY src needed
EXPOSE 5173

CMD ["pnpm", "run", "dev", "--", "--host", "0.0.0.0"]
