# ══════════════════════════════════════════════════════════════
# KidCode — Docker Compose environment
# Copy to .env and fill in your values.
# ══════════════════════════════════════════════════════════════

# ── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── GitHub OAuth (optional) ───────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:3030/api/github/callback

# ── CORS ──────────────────────────────────────────────────────
SPA_ORIGIN=http://localhost:5173

# ══════════════════════════════════════════════════════════════
# Option A — Cloud Supabase
# Fill these in when using a hosted Supabase project.
# Leave blank when using the local stack (Option B below).
# ══════════════════════════════════════════════════════════════
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ══════════════════════════════════════════════════════════════
# Option B — Local Supabase (docker-compose.local.yml)
# These are the well-known dev-only keys generated from JWT_SECRET.
# Safe to commit — meaningless without the matching secret.
# Run with:
#   docker compose -f docker-compose.yml -f docker-compose.local.yml up --build
# ══════════════════════════════════════════════════════════════
POSTGRES_PASSWORD=postgres
JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# anon key  (role: anon)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoiYW5vbiIsImlhdCI6MTYyMTQxNzM4MCwiZXhwIjo0Nzc3MDkxMzgwfQ.K5kqIqpxnIU5bkQVqDXiHbY5-HCWvTZ3Gjc6Vq7pJrs

# service role key  (role: service_role)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNjIxNDE3MzgwLCJleHAiOjQ3NzcwOTEzODB9.gcEFAhIbNXkFGjfZKH1PD5S26wA4kJdV3kMm6M0rp_E

# Local Supabase service URLs (for reference — set automatically by docker-compose.local.yml)
# Frontend (browser) → http://localhost:54321
# Postgres (direct)  → localhost:54322
# Studio dashboard   → http://localhost:54323
