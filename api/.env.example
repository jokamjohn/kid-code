# NestJS API — copy to .env for local development
# In Cloud Run: inject these as secrets via --set-secrets / Secret Manager

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase (server-side — use service role key, NOT anon key)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:3030/api/github/callback

# CORS — set to your Vite dev URL or Firebase Hosting URL
SPA_ORIGIN=http://localhost:5173

# Server port (Cloud Run injects this automatically; set for local dev)
PORT=3030
